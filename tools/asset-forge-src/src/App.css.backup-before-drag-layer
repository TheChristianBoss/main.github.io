:root {
  color: #f8fafc;
  background: #0f172a;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(250, 204, 21, 0.12), transparent 32rem),
    radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.08), transparent 28rem),
    #0f172a;
}

button,
input,
textarea,
select {
  font: inherit;
}

.app-shell {
  width: min(1220px, calc(100% - 32px));
  margin: 0 auto;
  padding: 48px 0;
}

.hero {
  margin-bottom: 28px;
}

.eyebrow {
  display: inline-flex;
  margin: 0 0 12px;
  padding: 6px 10px;
  border: 1px solid rgba(250, 204, 21, 0.35);
  border-radius: 999px;
  color: #fde68a;
  background: rgba(250, 204, 21, 0.08);
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

h1 {
  margin: 0;
  font-size: clamp(2.4rem, 6vw, 4.7rem);
  line-height: 0.95;
}

.hero p:last-child {
  max-width: 760px;
  color: #cbd5e1;
  font-size: 1.05rem;
  line-height: 1.6;
}

.workspace {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 24px;
  align-items: start;
}

.controls,
.preview-panel {
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 24px;
  background: rgba(15, 23, 42, 0.78);
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
}

.controls {
  padding: 22px;
}

.controls h2,
.preview-head h2 {
  margin: 0;
}

.preview-head {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 16px;
}

.preview-head p,
.template-note,
.privacy-note,
.upload-hint {
  color: #cbd5e1;
  line-height: 1.5;
}

.template-note,
.upload-panel {
  margin: -6px 0 18px;
  padding: 12px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 14px;
  background: rgba(2, 6, 23, 0.35);
  font-size: 0.94rem;
}

.upload-panel {
  margin-top: 4px;
}

.upload-panel label {
  margin-bottom: 10px;
}

.upload-hint,
.image-status,
.error-note,
.privacy-note {
  margin: 10px 0 0;
  font-size: 0.9rem;
}

.image-status {
  display: grid;
  gap: 10px;
  color: #e2e8f0;
}

.error-note {
  color: #fecaca;
}

label {
  display: grid;
  gap: 8px;
  margin-bottom: 16px;
  color: #e2e8f0;
  font-weight: 700;
}

input,
textarea,
select {
  width: 100%;
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 14px;
  padding: 12px 13px;
  color: #f8fafc;
  background: rgba(15, 23, 42, 0.92);
}

input[type="file"] {
  padding: 10px;
  cursor: pointer;
}

select {
  cursor: pointer;
}

textarea {
  resize: vertical;
}

.color-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.color-grid input {
  height: 48px;
  padding: 6px;
}

button {
  width: 100%;
  border: 0;
  border-radius: 16px;
  padding: 14px 18px;
  color: #111827;
  background: #facc15;
  font-weight: 900;
  cursor: pointer;
}

button:hover {
  filter: brightness(1.05);
}

.secondary-button {
  padding: 10px 12px;
  color: #f8fafc;
  background: rgba(148, 163, 184, 0.18);
  border: 1px solid rgba(148, 163, 184, 0.24);
}

.preview-panel {
  padding: 22px;
}

.canvas-frame {
  display: grid;
  place-items: center;
  overflow: hidden;
  border-radius: 20px;
  background:
    linear-gradient(45deg, rgba(148, 163, 184, 0.08) 25%, transparent 25%),
    linear-gradient(-45deg, rgba(148, 163, 184, 0.08) 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, rgba(148, 163, 184, 0.08) 75%),
    linear-gradient(-45deg, transparent 75%, rgba(148, 163, 184, 0.08) 75%),
    #020617;
  background-size: 34px 34px;
  background-position: 0 0, 0 17px, 17px -17px, -17px 0;
  padding: 18px;
  min-height: 560px;
}

canvas {
  display: block;
  max-width: 100%;
  max-height: 760px;
  width: auto;
  height: auto;
  border-radius: 12px;
  box-shadow: 0 18px 55px rgba(0, 0, 0, 0.45);
}

@media (max-width: 940px) {
  .workspace {
    grid-template-columns: 1fr;
  }

  .canvas-frame {
    min-height: 360px;
  }
}
.export-grid {
  display: grid;
  gap: 10px;
  margin-top: 10px;
}

.status-note {
  margin: 12px 0 0;
  color: #bbf7d0;
  font-size: 0.9rem;
  line-height: 1.5;
}

.single-export-button {
  margin-top: 10px;
}


.size-note {
  margin-top: -8px;
}


.image-controls {
  margin: 4px 0 18px;
  padding: 14px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 14px;
  background: rgba(2, 6, 23, 0.35);
}

.image-controls h3 {
  margin: 0 0 12px;
  font-size: 1rem;
}

.image-controls label {
  margin-bottom: 14px;
}

.image-controls label span {
  color: #fde68a;
  font-size: 0.86rem;
  font-weight: 800;
}

.image-controls input[type="range"] {
  padding: 0;
  accent-color: #facc15;
}
