{
  "name": "ats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm install && npm --prefix tools/asset-forge-src install",
    "dev": "npm run dev:ats",
    "dev:ats": "vite --config vite.ats.config.js",
    "dev:resume": "vite --config vite.resume.config.js",
    "dev:cover": "vite --config vite.cover.config.js",
    "dev:converter": "vite --config vite.converter.config.js",
    "dev:asset-forge": "npm --prefix tools/asset-forge-src run dev",
    "build": "node scripts/build-apps.mjs all",
    "build:all": "node scripts/build-apps.mjs all",
    "build:ats": "node scripts/build-apps.mjs ats",
    "build:resume": "node scripts/build-apps.mjs resume",
    "build:cover": "node scripts/build-apps.mjs cover",
    "build:converter": "node scripts/build-apps.mjs converter",
    "build:asset-forge": "node scripts/build-apps.mjs asset-forge",
    "build:verify": "node scripts/build-apps.mjs verify",
    "clean:builds": "node scripts/build-apps.mjs clean",
    "lint": "eslint src tools/converter-src/src tools/cover-src/src tools/asset-forge-src/src workers jobs scripts tests eslint.config.js vite.ats.config.js vite.resume.config.js vite.cover.config.js vite.converter.config.js tools/asset-forge-src/vite.config.js",
    "preview": "vite preview",
    "test:build-system": "node tests/build-system.test.mjs && node tests/build-coordinator-smoke.test.mjs",
    "test:converter-image-pdf": "node tools/converter-src/tests/image-pdf-smoke.mjs",
    "test:resume-pdf": "node tests/resume-pdf-layout.test.mjs && node tests/resume-pdf-smoke.mjs",
    "test:smoke": "node tests/application-smoke.test.mjs",
    "test:quality": "npm run lint && npm run test:smoke",
    "test:all": "npm run test:quality && npm run test:converter-image-pdf && npm run test:resume-pdf && node tools/converter-src/tests/service-worker.test.mjs && node store/tests/success-payment-verification.test.mjs && node workers/tests/store-payment-webhook.test.mjs && node workers/tests/store-order-kv-required.test.mjs && node tests/build-system.test.mjs && node tests/build-coordinator-smoke.test.mjs && node tests/cleanup-known-duplicates.test.mjs"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "jspdf": "4.2.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
